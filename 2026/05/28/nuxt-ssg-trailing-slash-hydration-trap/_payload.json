238,239],{},[33,233,200],{}," 的 key 里嵌了 ",[33,236,237],{},"route.path","，所以问题归结为一句话：",[25,240,241,242,244,245,247],{},"SSR 时的 ",[33,243,237],{}," 和客户端水合时的 ",[33,246,237],{}," 不一样。",[16,249,250,251,254],{},"把构建产物里的 ",[33,252,253],{},"_payload.json"," 抠出来看一眼：",[54,256,260],{"className":257,"code":258,"language":259,"meta":59,"style":59},"language-json shiki shiki-themes one-light one-dark-pro","{\"randomIndex/about\": ...}\n","json",[33,261,262],{"__ignoreMap":59},[63,263,264,267,270,272,276],{"class":65,"line":66},[63,265,266],{"class":73},"{",[63,268,269],{"class":77},"\"randomIndex/about\"",[63,271,81],{"class":73},[63,273,275],{"class":274},"sUNH4","...",[63,277,278],{"class":73},"}\n",[16,280,281,282,285,286,289,290,293,294,296,297,299,300,303,304,28],{},"key 是 ",[33,283,284],{},"randomIndex/about","，",[25,287,288],{},"没有尾斜杠","。可这个文件是 ",[33,291,292],{},".output/public/about/_payload.json","，也就是说浏览器访问的 URL 是 ",[33,295,22],{},"，客户端拿 ",[33,298,237],{}," 拼出来的 key 自然是 ",[33,301,302],{},"randomIndex/about/","——",[25,305,306],{},"多了一个斜杠",[16,308,309,310,312],{},"key 一错位，payload 命中失败，",[33,311,204],{}," 在客户端重跑，DOM 与服务端渲染的对不上，水合直接崩盘退化成一次 full re-render。",[45,314,316],{"id":315},"为什么-ssr-和客户端会不一致","为什么 SSR 和客户端会不一致",[16,318,319,320,323,324,327,328,330,331,28],{},"罪魁祸首是 Nitro 的 ",[33,321,322],{},"prerender.autoSubfolderIndex","（默认开）。它在 prerender 阶段会把 URL 归一化成\"目录形态\"，把 ",[33,325,326],{},"/about"," 改写成 ",[33,329,22],{},"，然后把结果落到 ",[33,332,333],{},"about/index.html",[16,335,336,337,340,341,349,350,28],{},"但归一化是在",[25,338,339],{},"进 vue-router 之前","做的，更准确地说，",[25,342,343,344,346,347],{},"SSR 内部看到的 ",[33,345,237],{}," 还停留在归一化之前的 ",[33,348,326],{},"，于是 payload 的 key 也用了 ",[33,351,326],{},[16,353,354,355,357,358,361,362,28],{},"而客户端这边，浏览器地址栏是 ",[33,356,22],{},"，vue-router 解析出 ",[33,359,360],{},"route.path === '/about/'","，key 自然变成 ",[33,363,22],{},[16,365,366],{},"一边写、一边读，斜杠的位置不一样，于是就出事了。",[45,368,370],{"id":369},"nuxt-有没有官方解","Nuxt 有没有官方解？",[16,372,373,374,28],{},"很遗憾，",[25,375,376],{},"没有",[16,378,379,385],{},[20,380,384],{"href":381,"rel":382},"https://github.com/nuxt/nuxt/issues/15462",[383],"nofollow","nuxt/nuxt#15462"," 是从 2022 年 11 月开到现在的 issue，标题就叫 \"Unified trailing slash handling\"，至今没合。Nuxt 现在能给的只有：",[54,387,389],{"className":56,"code":388,"language":58,"meta":59,"style":59},"// nuxt.config.ts\nexperimental: {\n  defaults: { nuxtLink: { trailingSlash: 'append' } }  // 只影响 NuxtLink 渲染出来的 href\n},\nsite: { trailingSlash: true }                          // 只影响 canonical / sitemap\n",[33,390,391,397,406,433,438],{"__ignoreMap":59},[63,392,393],{"class":65,"line":66},[63,394,396],{"class":395},"sW2Sy","// nuxt.config.ts\n",[63,398,399,403],{"class":65,"line":102},[63,400,402],{"class":401},"sz0mV","experimental",[63,404,405],{"class":73},": {\n",[63,407,408,411,414,417,419,422,424,427,430],{"class":65,"line":133},[63,409,410],{"class":401},"  defaults",[63,412,413],{"class":73},": { ",[63,415,416],{"class":401},"nuxtLink",[63,418,413],{"class":73},[63,420,421],{"class":401},"trailingSlash",[63,423,81],{"class":73},[63,425,426],{"class":105},"'append'",[63,428,429],{"class":73}," } }  ",[63,431,432],{"class":395},"// 只影响 NuxtLink 渲染出来的 href\n",[63,434,435],{"class":65,"line":192},[63,436,437],{"class":73},"},\n",[63,439,441,444,446,448,450,454,457],{"class":65,"line":440},5,[63,442,443],{"class":401},"site",[63,445,413],{"class":73},[63,447,421],{"class":401},[63,449,81],{"class":73},[63,451,453],{"class":452},"sAGMh","true",[63,455,456],{"class":73}," }                          ",[63,458,459],{"class":395},"// 只影响 canonical / sitemap\n",[16,461,462,463,466],{},"这两个加起来，能让\"我自己代码里发出去的链接\"全都带斜杠，但",[25,464,465],{},"对入站 URL 没有任何约束","——用户手敲、外部跳转、收藏夹里那条没斜杠的链接，照样能走进站点。",[16,468,469,470,472,473,476,477,479,480,28],{},"更糟糕的是，",[33,471,237],{}," 在 SSR / client / prerender / SPA 导航这几种上下文里",[25,474,475],{},"都可能不一样","，所以只要你在 ",[33,478,200],{}," 的 key 里用了它，",[25,481,482],{},"就是个雷",[45,484,486],{"id":485},"解法一根除-hydration-失败核心","解法一：根除 hydration 失败（核