ut___zh-{}\"",[63,734,81],{"class":73},[63,736,275],{"class":274},[63,738,130],{"class":73},[63,740,741,744,746],{"class":65,"line":192},[63,742,743],{"class":77},"  \"language-switch-about___zh-{}-en\"",[63,745,81],{"class":73},[63,747,748],{"class":274},"...\n",[63,750,751],{"class":65,"line":440},[63,752,278],{"class":73},[16,754,755,756,28],{},"干干净净，",[25,757,758],{},"无论 URL 带不带斜杠都能命中",[760,761,762],"blockquote",{},[16,763,764,765,767,768,770,771,774,775,777],{},"顺手把本站所有 ",[33,766,200],{}," 都过了一遍，能用 ",[33,769,515],{}," 直接拼的（比如文章详情页用 ",[33,772,773],{},"year/month/day/slug","）都已经是安全的；剩下用 ",[33,776,237],{}," 拼 key 的全部改掉。",[45,779,781],{"id":780},"解法二纯前端兜底入站-urlux","解法二：纯前端兜底入站 URL（UX）",[16,783,784,785,788,789,791,792,794],{},"数据层修好了，但用户地址栏里",[25,786,787],{},"那个没斜杠的 URL 还在","。SEO 模块算出来的 canonical 是 ",[33,790,22],{},"，浏览器显示的是 ",[33,793,326],{},"——别扭。",[16,796,797,798,801],{},"最经典的解法是 server 端 301，但我这个博客是 ",[25,799,800],{},"Vercel + Caddy 双站点部署","，做 301 就得分别为两个平台写规则，能避免就避免。而且博客是 SSG，没有运行时 server。",[16,803,804,805,808],{},"那就",[25,806,807],{},"纯前端兜底","，写一个 global middleware 把所有入站的无斜杠路径规范化：",[54,810,812],{"className":56,"code":811,"language":58,"meta":59,"style":59},"// app/middleware/trailing-slash.global.ts\nexport default defineNuxtRouteMiddleware((to) => {\n  if (import.meta.server) return\n  if (to.path === '/' || to.path.endsWith('/')) return\n\n  // 跳过 /favicon.ico、/rss.xml 这种带后缀的资源路径\n  const lastSegment = to.path.slice(to.path.lastIndexOf('/') + 1)\n  if (lastSegment.includes('.')) return\n\n  return navigateTo(\n    { path: to.path + '/', query: to.query, hash: to.hash },\n    { replace: true }\n  )\n})\n",[33,813,814,819,846,872,915,919,924,972,996,1001,1012,1065,1081,1087],{"__ignoreMap":59},[63,815,816],{"class":65,"line":66},[63,817,818],{"class":395},"// app/middleware/trailing-slash.global.ts\n",[63,820,821,824,828,831,834,838,841,843],{"class":65,"line":102},[63,822,823],{"class":69},"export",[63,825,827],{"class":826},"sq3v1"," default",[63,829,830],{"class":95}," defineNuxtRouteMiddleware",[63,832,833],{"class":73},"((",[63,835,837],{"class":836},"s8iYz","to",[63,839,840],{"class":73},") ",[63,842,142],{"class":69},[63,844,845],{"class":73}," {\n",[63,847,848,851,854,857,859,862,864,867,869],{"class":65,"line":133},[63,849,850],{"class":69},"  if",[63,852,853],{"class":73}," (",[63,855,856],{"class":69},"import",[63,858,118],{"class":73},[63,860,861],{"class":77},"meta",[63,863,118],{"class":73},[63,865,866],{"class":77},"server",[63,868,840],{"class":73},[63,870,871],{"class":69},"return\n",[63,873,874,876,878,880,882,884,887,890,893,896,898,900,902,905,907,910,913],{"class":65,"line":192},[63,875,850],{"class":69},[63,877,853],{"class":73},[63,879,837],{"class":113},[63,881,118],{"class":73},[63,883,121],{"class":77},[63,885,886],{"class":91}," ===",[63,888,889],{"class":105}," '/'",[63,891,892],{"class":91}," ||",[63,894,895],{"class":113}," to",[63,897,118],{"class":73},[63,899,121],{"class":175},[63,901,118],{"class":73},[63,903,904],{"class":95},"endsWith",[63,906,153],{"class":73},[63,908,909],{"class":105},"'/'",[63,911,912],{"class":73},")) ",[63,914,871],{"class":69},[63,916,917],{"class":65,"line":440},[63,918,619],{"emptyLinePlaceholder":618},[63,920,921],{"class":65,"line":658},[63,922,923],{"class":395},"  // 跳过 /favicon.ico、/rss.xml 这种带后缀的资源路径\n",[63,925,926,929,932,934,936,938,940,942,945,947,949,951,953,955,958,960,962,964,967,970],{"class":65,"line":701},[63,927,928],{"class":69},"  const",[63,930,931],{"class":84}," lastSegment",[63,933,534],{"class":91},[63,935,895],{"class":113},[63,937,118],{"class":73},[63,939,121],{"class":175},[63,941,118],{"class":73},[63,943,944],{"class":95},"slice",[63,946,153],{"class":73},[63,948,837],{"class":113},[63,950,118],{"class":73},[63,952,121],{"class":175},[63,954,118],{"class":73},[63,956,957],{"class":95},"lastIndexOf",[63,959,153],{"class":73},[63,961,909],{"class":105},[63,963,840],{"class":73},[63,965,966],{"class":91},"+",[63,968,969],{"class":452}," 1",[63,971,189],{"class":73},[63,973,975,977,979,982,984,987,989,992,994],{"class":65,"line":974},8,[63,976,850],{"class":69},[63,978,853],{"class":73},[63,980,981],{"class":113},"lastSegment",[63,983,118],{"class":73},[63,985,986],{"class":95},"includes",[63,988,153],{"class":73},[63,990,991],{"class":105},"'.'",[63,993,912],{"class":73},[63,995,871],{"class":69},[63,997,999],{"class":65,"line":998},9,[63,1000,619],{"emptyLinePlaceholder":618},[63,1002,1004,1007,1010],{"class":65,"line":1003},10,[63,1005,1006],{"class":69},"  return",[63,1008,1009],{"class":95}," navigateTo",[63,1011,99],{"class":73},[63,1013,1015,1018,1020,1024,1026,1028,1030,1033,1035,1038,1041,1043,1045,1047,1049,1051,1054,1056,1058,1060,1062],{"class":65,"line":1014},11,[63,1016,1017],{"class":73},"    { ",[63,1019,121],{"class":77},[63,1021,1023],{"class":1022},"st7oF",":",[63,1025,895],{"class":113},[63,1027,118],{"class":73},[63,1029,121],{"class":77},[63,1031,1032],{"class":91}," +",[63,1034,889],{"class":105},[63,1036,1037],{"class":73},", ",[63,1039,1040],{"class":77},"query",[63,1042,1023],{"class":1022},[63,1044,895],{"class":113},[63,1046,118],{"class":73},[63,1048,1040],{"class":77},[63,1050,1037],{"class":73},[63,1052,1053],{"class":77},"hash",[63,1055,1023],{"class":1022},[63,1057,895],{"class":113},[63,1059,118],{"class":73},[63,1061,1053],{"class":77},[63,1063,1064],{"class":73}," },\n",[63,1066,1068,1070,1073,1075,1078],{"class":65,"line":1067},12,[63,1069,1017],{"class":73},[63,1071,1072],{"class":77},"replace",[63,1074,1023],{"class":1022},[63,1076,1077],{"class":452}," true",[63,1079,1080],{"class":73}," }\n",[63,1082,1084],{"class":65,"line":1083},13,[63,1085,1086],{"class":73},"  )\n",[63,1088,1090],{"class":65,"line":1089},14,[63,1091,1092],{"class":73},"})\n",[16,1094,1095],{},"几个关键点：",[498,1097,1098,1108,1114],{},[501,1099,1100,1103,1104,1107],{},[33,1101,1102],{},"import.meta.server"," 直接返回。SSG prerender 阶段 Nitro 已经把路径归一化好了，再在 middleware 里 ",[33,1105,1106],{},"navigateTo"," 反而可能在产物里写出一堆 30x。",[501,1109,1110,1113],{},[33,1111,1112],{},"replace: true"," 让浏览器直接替换 history，不会留下一条\"刚刚那个没斜杠版本\"的返回栈。",[501,1115,1116,1117,1119],{},"排除带 ",[33,1118,118],{}," 的\"看起来像文件\"的路径，避免误伤静态资源。",[16,1121,1122,1123,1125,1126,1128,1129,1131,1132,1135],{},"水合完成 → middleware 执行 → URL 在地址栏里被悄悄改成 ",[33,1124,22],{},"。因为前面解法一已经让 ",[33,1127,200],{}," 的 key 与路径解耦了，这次 ",[33,1130,1106],{}," 触发的导航",[25,1133,1134],{},"不会","重新 fetch 数据，也不会丢状态，肉眼上是无感知的。",[45,1137,1138],{"id":1138},"整体策略",[16,1140,1141],{},"最终落地的尾斜杠策略可以用一句话总结：",[760,1143,1144],{},[16,1145,1146],{},[25,1147,1148,1149,1152,1153,1156],{},"prerender 时让 Nitro 把所有路径落到 ",[33,1150,1151],{},"xxx/index.html","，出站链接由 NuxtLink + ",[33,1154,1155],{},"trailingSlash: 'append'"," 自动补，入站直链由全局 client middleware 兜底，全链路 0 个 HTTP 301。",[16,1158,1159],{},"对照一下各个层面：",[1161,1162,1163,1176],"table",{},[1164,1165,1166],"thead",{},[1167,1168,1169,1173],"tr",{},[1170,1171,1172],"th",{},"场景",[1170,1174,1175],{},"谁负责",[1177,1178,1179,1191,1201,1215,1223],"tbody",{},[1167,1180,1181,1185],{},[1182,1183,1184],"td",{},"Prerender 落地",[1182,1186,1187,1188],{},"Nitro ",[33,1189,1190],{},"autoSubfolderIndex",[1167,1192,1193,1196],{},[1182,1194,1195],{},"SEO canonical / sitemap",[1182,1197,1198],{},[33,1199,1200],{},"site.trailingSlash: true",[1167,1202,1203,1210],{},[1182,1204,1205,1206,1209],{},"自己代码里 ",[33,1207,1208],{},"\u003CNuxtLink>"," 渲染的 href",[1182,1211,1212],{},[33,1213,1214],{},"nuxtLink.trailingSlash: 'append'",[1167,1216,1217,1220],{},[1182,1218,1219],{},"用户手敲 / 外链 / 收藏夹",[1182,1221,1222],{},"global client middleware",[1167,1224,1225,1230],{},[1182,1226,1227,1229],{},[33,1228,200],{}," 在两端命中同一个 payload",[1182,1231,1232,1233,1236,1237],{},"key 用 ",[33,1234,1235],{},"route.name + params","，不沾 ",[33,1238,237],{},[45,1240,1241],{"id":1241},"一些没踩但容易踩的坑",[498,1243,1244,1256,1276],{},[501,1245,1246,1251,1252,1255],{},[25,1247,1248,1250],{},[33,1249,237],{}," 在 SSR 时和 prerender 后的实际 URL 不一定一致","，所以只要它出现在任何\"需要在两端一致\"的地方（cache key、SSR-only 计算后 emit、",[33,1253,1254],{},"\u003Cmeta>"," 标签内容等等）都要警惕。",[501,1257,1258,1267,1268,1271,1272,1275],{},[25,1259,1260,1263,1264,1266],{},[33,1261,1262],{},"NuxtLink"," 的 ",[33,1265,1155],{}," 只影响渲染出来的 href","，不影响 ",[33,1269,1270],{},"router.push('/about')"," 这种代码调用。如果你在代码里手动 push，要么自己拼斜杠，要么走 ",[33,1273,1274],{},"localePath"," 之类的辅助函数。",[501,1277,1278,1281],{},[25,1279,1280],{},"client middleware 不能修复 hydration mismatch","——它跑得太晚，HTML 已经发出去并开始水合了。所以解法一（key 与路径解耦）才是治本，middleware 只是治标的 UX 兜底。",[45,1283,1284],{"id":1284},"写在最后",[16,1286,1287],{},"这事让我多少有点意外。Nuxt 已经迭代到 v4 了，SSG / i18n / Content 也都是它的\"主推\"组合，但尾斜杠这种\"看起来应该是配置一行就完事\"的东西，仍然要业务侧自己拼一套方案出来，多少让人有点 emo。",[16,1289,1290,1291,1294],{},"如果你也是 Nuxt SSG + i18n 的栈，建议立刻 grep 一下自己项目里所有 ",[33,1292,1293],{},"useAsyncData(\\","...${route.path}...``，看完估计能找到不止一个雷。",[1296,1297,1298],"style",{},"html pre.shiki code .sLKXg, html code.shiki .sLKXg{--shiki-default:#A626A4;--shiki-dark:#C678DD}html pre.shiki code .s5ixo, html code.shiki .s5ixo{--shiki-default:#383A42;--shiki-dark:#ABB2BF}html pre.shiki code .sJa8x, html code.shiki .sJa8x{--shiki-default:#E45649;--shiki-dark:#E06C75}html pre.shiki code .sNmU0, html code.shiki .sNmU0{--shiki-default:#986801;--shiki-dark:#E5C07B}html pre.shiki code .s_Sar, html code.shiki .s_Sar{--shiki-default:#0184BC;--shiki-dark:#56B6C2}html pre.shiki code .sAdtL, html code.shiki .sAdtL{--shiki-default:#4078F2;--shiki-dark:#61AFEF}html pre.shiki code .sDhpE, html code.shiki .sDhpE{--shiki-default:#50A14F;--shiki-dark:#98C379}html pre.shiki code .sAOjX, html code.shiki .sAOjX{--shiki-default:#CA1243;--shiki-dark:#C678DD}html pre.shiki code .s7GmK, html code.shiki .s7GmK{--shiki-default:#383A42;--shiki-dark:#E5C07B}html pre.shiki code .sMj0N, html code.shiki .sMj0N{--shiki-default:#50A14F;--shiki-dark:#ABB2BF}html pre.shiki code .s2QsP, html code.shiki .s2QsP{--shiki-default:#E45649;--shiki-dark:#E5C07B}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);fo